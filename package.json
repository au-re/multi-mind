{
  "name": "multi-mind",
  "private": true,
  "type": "module",
  "author": "Prompt Studio",
  "email": "support@prompt.studio",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pufflyai/prompt-studio.git"
  },
  "scripts": {
    "build": "bunx cross-env NODE_OPTIONS=\"--max-old-space-size=8192\" lerna run build",
    "analyze-bundle": "bunx lerna run analyze-bundle --stream",
    "test": "bunx lerna run test --stream --no-prefix --ignore e2e -- --reporter dot --silent",
    "test:e2e": "bun run --cwd e2e test",
    "lint": "bunx lerna run lint",
    "format": "bunx biome check --write .",
    "format:check": "bunx biome check .",
    "clean": "find . -type d \\( -name node_modules -o -name dist -o -name .cache \\) -prune -exec rm -rf '{}' + && rm -rf .nx",
    "knip": "bunx knip",
    "report:e2e": "bun run --cwd e2e report"
  },
  "engines": {
    "bun": ">=1.3.10"
  },
  "workspaces": [
    "e2e",
    "packages/shared",
    "packages/traits",
    "packages/blackboard",
    "packages/engine",
    "packages/memory",
    "webapp"
  ],
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "@types/bun": "latest",
    "@types/node": "^24.8.1",
    "cross-env": "^10.0.0",
    "knip": "^5.66.1",
    "lerna": "^9.0.1"
  },
  "packageManager": "bun@1.3.10"
}
